# Kekuleon (KRTC) — environment variables template.
#
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Do NOT commit `.env.local` or any file containing real secrets.

# ---------------------------------------------------------------------------
# Email — Resend
# ---------------------------------------------------------------------------
# Used by:
#   - app/api/contact/route.ts        (contact form submissions)
#   - app/api/seminar-register/route.ts (seminar registration confirmations)
#
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Seminar registration → Google Sheets (optional)
# ---------------------------------------------------------------------------
# When set, every successful seminar registration is POSTed to this URL so
# entries land in a connected Google Sheet. Leave empty to skip the webhook.
# Used by: app/api/seminar-register/route.ts
SEMINAR_SHEETS_WEBHOOK_URL=

# Shared secret sent in the `X-Webhook-Secret` header to authenticate the
# webhook on the receiving side. Required if SEMINAR_SHEETS_WEBHOOK_URL is set.
SEMINAR_SHEETS_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Rate limiting — Upstash Redis
# ---------------------------------------------------------------------------
# Powers per-IP and per-email/registration rate limiting for both API routes
# (app/api/contact + app/api/seminar-register). Without these, rate limiting
# is DISABLED (requests are allowed) — the app still runs, but the anti-abuse
# / anti-email-bombing protection is off. Used by: lib/ratelimit.ts
#
# Create a free database at https://console.upstash.com (or via the Vercel
# Upstash integration), then copy its REST URL + token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Analytics (optional)
# ---------------------------------------------------------------------------
# Google Analytics 4 measurement ID. If unset, the production default
# (G-3G556LZGJB) is used. Override per-environment (staging/preview) to
# avoid polluting production analytics.
NEXT_PUBLIC_GA_ID=
